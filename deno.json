{
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "fmt": {
    "lineWidth": 120
  },
  "tasks": {
    "start": "deno run --allow-all src/index.ts",
    "deploy-commands": "deno run --allow-all src/deploy-commands.ts",
    "delete-all-commands": "deno run --allow-all src/delete-all-commands.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "deno run --allow-all src/database/migrate.ts",
    "test": "deno test --allow-all --parallel tests/",
    "check": "deno fmt && deno lint && deno check src/**/*.ts && deno test --allow-all --parallel tests/"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "@std/dotenv": "https://deno.land/std@0.224.0/dotenv/mod.ts",
    "@std/log": "https://deno.land/std@0.224.0/log/mod.ts",
    "canvas": "npm:canvas@^3.2.1",
    "discord.js": "npm:discord.js@^14.25.1",
    "drizzle-orm": "npm:drizzle-orm@^0.45.1",
    "drizzle-kit": "npm:drizzle-kit@^0.31.9",
    "html-entities": "npm:html-entities@^2.6.0",
    "date-fns": "npm:date-fns@^4.1.0",
    "mysql2": "npm:mysql2@^3.18.2",
    "node-cron": "npm:node-cron@^4.2.1",
    "turndown": "npm:turndown@^7.2.2"
  }
}
